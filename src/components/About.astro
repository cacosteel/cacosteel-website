---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="About CACO Steel">

<section class="page-hero">

    <div class="container">

        <span class="section-tag">ABOUT CACO</span>

        <h1>Your Trusted Steel Export Partner from Türkiye</h1>

        <p>
            CACO Steel connects international buyers with Türkiye's leading steel manufacturers,
            delivering certified products, dependable logistics and long-term business partnerships.
        </p>

    </div>

</section>

<section class="about-story">

    <div class="container">

        <div class="about-grid">

            <div>

                <h2>Who We Are</h2>

                <p>
                    Established in 2019, CACO Steel is an international steel export company
                    built on more than 23 years of business development experience in the steel industry.
                </p>

                <p>
                    We cooperate with carefully selected Turkish manufacturers to supply
                    certified steel products for construction, infrastructure, manufacturing,
                    renewable energy and industrial projects worldwide.
                </p>

                <p>
                    Our objective is simple: provide competitive quotations, dependable supply,
                    transparent communication and long-term partnerships with every customer.
                </p>

            </div>

            <div class="about-box">

                <h3>Why Choose CACO</h3>

                <ul>

                    <li>✓ 23+ years of international experience</li>
                    <li>✓ Reliable Turkish manufacturing partners</li>
                    <li>✓ Certified quality products</li>
                    <li>✓ Worldwide export expertise</li>
                    <li>✓ Response to inquiries within 48 hours</li>
                    <li>✓ Customer-focused long-term partnerships</li>

                </ul>

            </div>

        </div>

    </div>

</section>

<section class="mission">

    <div class="container">

        <div class="mission-grid">

            <div class="mission-card">

                <h2>Our Mission</h2>

                <p>
                    To deliver reliable steel supply solutions by connecting international customers
                    with Türkiye's most trusted steel producers through quality, transparency and professional service.
                </p>

            </div>

            <div class="mission-card">

                <h2>Our Vision</h2>

                <p>
                    To become one of the world's most trusted international steel sourcing partners,
                    recognized for reliability, integrity and long-term business relationships.
                </p>

            </div>

        </div>

    </div>

</section>

<section class="values">

    <div class="container">

        <h2>Our Core Values</h2>

        <div class="value-grid">

            <div class="value-card">
                <h3>Integrity</h3>
                <p>We build trust through honesty, transparency and ethical business practices.</p>
            </div>

            <div class="value-card">
                <h3>Quality</h3>
                <p>Every shipment meets internationally recognized quality standards.</p>
            </div>

            <div class="value-card">
                <h3>Reliability</h3>
                <p>Consistent communication and dependable delivery throughout every project.</p>
            </div>

            <div class="value-card">
                <h3>Partnership</h3>
                <p>We believe successful business is built on long-term cooperation.</p>
            </div>

            <div class="value-card">
                <h3>Professionalism</h3>
                <p>Experienced support from inquiry to final shipment.</p>
            </div>

            <div class="value-card">
                <h3>Sustainability</h3>
                <p>Supporting responsible sourcing and environmentally conscious production.</p>
            </div>

        </div>

    </div>

</section>

</MainLayout>