---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="About CACO">

<section class="page-hero">

    <div class="container">

        <span class="section-tag">
            ABOUT CACO
        </span>

        <h1>Building Global Partnerships Through Steel</h1>

        <p>
            CACO is an international steel export company based in Antalya,
            Türkiye, supplying certified steel products to customers
            worldwide with quality, reliability and professional service.
        </p>

    </div>

</section>

<section class="about-story">

    <div class="container">

        <div class="about-grid">

            <div>

                <h2>Who We Are</h2>

                <p>
                    Founded in 2019 by Günüz, CACO combines more than
                    twenty years of international steel industry experience
                    with strong partnerships across Türkiye's leading steel
                    manufacturers.
                </p>

                <p>
                    We focus exclusively on export markets, delivering
                    high-quality steel products for construction,
                    infrastructure, manufacturing and renewable energy
                    projects worldwide.
                </p>

            </div>

            <div class="about-box">

                <h3>Why Companies Choose CACO</h3>

                <ul>

                    <li>✔ 20+ years of steel industry experience</li>

                    <li>✔ Reliable Turkish manufacturing partners</li>

                    <li>✔ International logistics expertise</li>

                    <li>✔ Certified quality products</li>

                    <li>✔ Customer-focused approach</li>

                </ul>

            </div>

        </div>

    </div>

</section>

<section class="mission">

    <div class="container">

        <div class="mission-grid">

            <div class="mission-card">

                <h2>Our Mission</h2>

                <p>
                    To provide high-quality steel solutions that help our
                    international customers successfully deliver industrial,
                    infrastructure and renewable energy projects.
                </p>

            </div>

            <div class="mission-card">

                <h2>Our Vision</h2>

                <p>
                    To become one of the most trusted international steel
                    export partners by combining quality, innovation,
                    sustainability and outstanding customer service.
                </p>

            </div>

        </div>

    </div>

</section>

<section class="values">

    <div class="container">

        <h2>Our Core Values</h2>

        <div class="value-grid">

            <div class="value-card">
                <h3>Quality</h3>
                <p>Every product meets demanding international standards.</p>
            </div>

            <div class="value-card">
                <h3>Integrity</h3>
                <p>Honest communication and transparent business practices.</p>
            </div>

            <div class="value-card">
                <h3>Innovation</h3>
                <p>Continuous improvement in products and services.</p>
            </div>

            <div class="value-card">
                <h3>Sustainability</h3>
                <p>Responsible sourcing and environmentally conscious solutions.</p>
            </div>

            <div class="value-card">
                <h3>Responsibility</h3>
                <p>Reliable execution from quotation to final delivery.</p>
            </div>

            <div class="value-card">
                <h3>Customer Focus</h3>
                <p>Long-term partnerships built on trust and service.</p>
            </div>

        </div>

    </div>

</section>