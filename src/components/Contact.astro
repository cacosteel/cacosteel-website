---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Contact CACO">

<section class="page-hero">

    <div class="container">

        <span class="section-tag">
            CONTACT
        </span>

        <h1>Let's Discuss Your Steel Requirements</h1>

        <p>
            Whether you need a quotation, technical advice or information
            about international steel supply, our team is ready to assist.
        </p>

    </div>

</section>

<section class="contact-page">

    <div class="container">

        <div class="contact-grid">

            <div class="contact-info">

                <h2>Contact Information</h2>

                <div class="contact-item">
                    <h3>📍 Headquarters</h3>
                    <p>Antalya, Türkiye</p>
                </div>

                <div class="contact-item">
                    <h3>✉ Email</h3>
                    <p>info@cacosteel.com</p>
                </div>

                <div class="contact-item">
                    <h3>🌍 Business</h3>
                    <p>International Steel Export Only</p>
                </div>

                <div class="contact-item">
                    <h3>🚢 Markets</h3>
                    <p>Worldwide Supply & Logistics</p>
                </div>

            </div>

            <form class="contact-form">

                <input type="text" placeholder="First Name*" required>

                <input type="text" placeholder="Last Name*" required>

                <input type="text" placeholder="Company Name*" required>

                <input type="text" placeholder="VAT Number">

                <input type="email" placeholder="Email*" required>

                <input type="tel" placeholder="Telephone">

                <textarea rows="7" placeholder="Message*" required></textarea>

                <button type="submit" class="btn-primary">
                    Send Message
                </button>

            </form>

        </div>

    </div>

</section>

</MainLayout>