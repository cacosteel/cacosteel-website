---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Steel Products | CACO Steel">

<section class="page-hero">

    <div class="container">

        <span class="section-tag">PRODUCTS</span>

        <h1>International Steel Products</h1>

        <p>
            CACO Steel supplies certified steel products from Türkiye's leading manufacturers,
            serving construction, infrastructure, manufacturing and energy industries worldwide.
        </p>

    </div>

</section>

<section class="products-page">

    <div class="container">

        <div class="product-grid">

            <div class="product-card">
                <h3>Flat Steel Products</h3>
                <p>
                    Hot Rolled, Cold Rolled, Galvanized, Electro Galvanized,
                    PPGI, PPGL, Tinplate and Tin Free Steel.
                </p>
            </div>

            <div class="product-card">
                <h3>Long Steel Products</h3>
                <p>
                    Rebars, Wire Rod, Merchant Bars, IPE, HEA, HEB,
                    UPN, Angles, Channels and Structural Sections.
                </p>
            </div>

            <div class="product-card">
                <h3>Pipes & Tubes</h3>
                <p>
                    Seamless Pipes, ERW Pipes, Welded Tubes,
                    Galvanized Tubes and Hollow Sections.
                </p>
            </div>

            <div class="product-card">
                <h3>Steel Fasteners</h3>
                <p>
                    Bolts, Nuts, Screws, Washers,
                    Threaded Rods and Structural Fasteners.
                </p>
            </div>

            <div class="product-card">
                <h3>Special Steel</h3>
                <p>
                    Alloy Steel, Tool Steel,
                    Electrical Steel, Spring Steel
                    and Weathering (Corten) Steel.
                </p>
            </div>

            <div class="product-card">
                <h3>Renewable Energy Steel</h3>
                <p>
                    Solar Mounting Systems,
                    Wind Tower Components,
                    Transmission Towers and Custom Fabrication.
                </p>
            </div>

        </div>

    </div>

</section>

<section class="cta-light">

    <div class="container">

        <h2>Can't Find Your Required Product?</h2>

        <p>
            Send us your technical specifications and our team will prepare
            the most suitable offer from our manufacturing partners within 48 hours.
        </p>

        <a href="/contact" class="btn-primary">
            Request a Quote
        </a>

    </div>

</section>

</MainLayout>