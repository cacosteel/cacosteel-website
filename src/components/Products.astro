---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Steel Products | CACO">

<section class="page-hero">

    <div class="container">

        <span class="section-tag">
            PRODUCTS
        </span>

        <h1>International Steel Products</h1>

        <p>
            We supply certified Turkish steel products for construction,
            manufacturing, infrastructure and renewable energy projects worldwide.
        </p>

    </div>

</section>

<section class="products-page">

    <div class="container">

        <div class="product-grid">

            <div class="product-card">
                <h3>Flat Steel</h3>
                <p>Hot Rolled (HRC), Cold Rolled (CRC), Galvanized, PPGI, PPGL, Tinplate and Tin-Free Steel.</p>
            </div>

            <div class="product-card">
                <h3>Long Steel</h3>
                <p>Rebars, wire rod, merchant bars, structural beams, rails and steel sections.</p>
            </div>

            <div class="product-card">
                <h3>Steel Tubes & Profiles</h3>
                <p>Seamless pipes, welded tubes, galvanized tubes and custom steel profiles.</p>
            </div>

            <div class="product-card">
                <h3>Special Steel</h3>
                <p>Tool steel, alloy steel, electrical steel and weathering (Corten) steel.</p>
            </div>

            <div class="product-card">
                <h3>Steel Fasteners</h3>
                <p>Bolts, nuts, screws, washers, threaded rods, rivets and industrial fasteners.</p>
            </div>

            <div class="product-card">
                <h3>Renewable Energy Solutions</h3>
                <p>Solar mounting structures, transmission towers, wind energy components and custom fabricated steel.</p>
            </div>

        </div>

    </div>

</section>

<section class="cta-light">

    <div class="container">

        <h2>Looking for a specific steel product?</h2>

        <p>
            Our team can recommend the most suitable solution for your project and provide a competitive quotation.
        </p>

        <a href="/contact" class="btn-primary">
            Request a Quote
        </a>

    </div>

</section>