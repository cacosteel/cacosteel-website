---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Steel Export Services | CACO">

<section class="page-hero">

    <div class="container">

        <span class="section-tag">
            SERVICES
        </span>

        <h1>Comprehensive Steel Export Services</h1>

        <p>
            We provide complete commercial, technical and logistics support,
            ensuring a smooth and reliable export process from inquiry to delivery.
        </p>

    </div>

</section>

<section class="services-page">

    <div class="container">

        <div class="service-grid">

            <div class="service-card">
                <h3>Commercial Representation</h3>
                <p>
                    We represent steel manufacturers and connect them with
                    international buyers through our global business network.
                </p>
            </div>

            <div class="service-card">
                <h3>Global Market Development</h3>
                <p>
                    Helping companies expand into new international markets
                    through market analysis and business development.
                </p>
            </div>

            <div class="service-card">
                <h3>Order Tracking & Logistics</h3>
                <p>
                    End-to-end management from production scheduling to
                    worldwide delivery and shipment tracking.
                </p>
            </div>

            <div class="service-card">
                <h3>Technical Consulting</h3>
                <p>
                    Guidance in selecting the most suitable steel products
                    for industrial, infrastructure and energy projects.
                </p>
            </div>

            <div class="service-card">
                <h3>Documentation & Compliance</h3>
                <p>
                    Export documentation, customs procedures, certificates
                    and international regulatory compliance.
                </p>
            </div>

            <div class="service-card">
                <h3>After-Sales Support</h3>
                <p>
                    Continuous communication and assistance after delivery
                    to ensure customer satisfaction.
                </p>
            </div>

        </div>

    </div>

</section>

<section class="cta-light">

    <div class="container">

        <h2>Need a reliable export partner?</h2>

        <p>
            CACO manages every stage of the international steel supply chain,
            allowing you to focus on your business.
        </p>

        <a href="/contact" class="btn-primary">
            Contact Our Team
        </a>

    </div>

</section>

</MainLayout>