---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="About | CACO Steel">

<section class="page-hero">
  <div class="container">
    <h1>About CACO Steel</h1>
    <p>
      CACO Steel is an international steel export company based in Antalya,
      Türkiye, connecting leading Turkish manufacturers with customers around
      the world.
    </p>
  </div>
</section>

<section class="container">
  <h2>Who We Are</h2>

  <p>
    We specialize in supplying certified steel products for construction,
    infrastructure, renewable energy, industrial manufacturing and engineering
    projects. Our mission is to provide reliable sourcing, competitive pricing,
    and dependable international logistics.
  </p>

  <br />

  <h2>Our Vision</h2>

  <p>
    To become one of the most trusted international partners for Turkish steel
    exports by building long-term relationships based on quality, transparency
    and service.
  </p>

</section>

</MainLayout>