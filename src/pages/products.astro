---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Products | CACO Steel">

<section class="page-hero">
    <div class="container">
        <h1>Steel Products</h1>

        <p>
            We supply high-quality Turkish steel products for construction,
            infrastructure, manufacturing and renewable energy projects.
        </p>
    </div>
</section>

<section class="products">

    <div class="container">

        <div class="product-grid">

            <div class="product-card">
                <h3>Flat Steel</h3>
                <p>Hot Rolled, Cold Rolled, Galvanized, PPGI, PPGL and Tinplate products.</p>
            </div>

            <div class="product-card">
                <h3>Long Steel</h3>
                <p>Rebars, wire rod, beams, channels, angles and structural sections.</p>
            </div>

            <div class="product-card">
                <h3>Steel Tubes</h3>
                <p>Seamless, welded and galvanized steel tubes and profiles.</p>
            </div>

            <div class="product-card">
                <h3>Fasteners</h3>
                <p>Bolts, nuts, washers, threaded rods and industrial fasteners.</p>
            </div>

            <div class="product-card">
                <h3>Renewable Energy</h3>
                <p>Steel structures and components for solar and wind energy projects.</p>
            </div>

        </div>

    </div>

</section>

</MainLayout>