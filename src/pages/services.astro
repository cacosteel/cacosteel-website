---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Services | CACO Steel">

<section class="page-hero">
    <div class="container">
        <h1>Our Services</h1>

        <p>
            We provide complete international trade support from supplier
            selection to worldwide delivery.
        </p>
    </div>
</section>

<section class="services">

    <div class="container">

        <div class="service-grid">

            <div class="service-card">
                <h3>Commercial Representation</h3>
                <p>Connecting manufacturers with international buyers.</p>
            </div>

            <div class="service-card">
                <h3>International Logistics</h3>
                <p>Sea freight, customs procedures and global delivery.</p>
            </div>

            <div class="service-card">
                <h3>Export Documentation</h3>
                <p>Invoices, certificates and export compliance documents.</p>
            </div>

            <div class="service-card">
                <h3>Technical Support</h3>
                <p>Helping customers select the right steel products.</p>
            </div>

            <div class="service-card">
                <h3>Project Supply</h3>
                <p>Complete steel supply management for international projects.</p>
            </div>

            <div class="service-card">
                <h3>After Sales Support</h3>
                <p>Continuous customer assistance after shipment.</p>
            </div>

        </div>

    </div>

</section>

</MainLayout>