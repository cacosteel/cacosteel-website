---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Terms & Policies | CACO Steel">

<section class="page-hero">

    <div class="container">

        <h1>Terms & Policies</h1>

        <p>
            Information regarding the use of our website and international
            steel export services.
        </p>

    </div>

</section>

<section class="legal-page">

    <div class="container">

        <div class="legal-section">

            <h2>Terms & Conditions</h2>

            <p>
                By using this website you agree to these terms and conditions.
                Information is provided for commercial purposes and may change
                without notice.
            </p>

        </div>

        <div class="legal-section">

            <h2>Privacy Policy</h2>

            <p>
                Personal information submitted through our website is used only
                to respond to enquiries and provide our services.
            </p>

        </div>

        <div class="legal-section">

            <h2>Shipping & Delivery</h2>

            <p>
                Delivery schedules depend on production planning,
                destination and customs procedures.
            </p>

        </div>

        <div class="legal-section">

            <h2>Returns & Claims</h2>

            <p>
                Claims should be reported promptly after delivery and will be
                reviewed according to the agreed commercial terms.
            </p>

        </div>

    </div>

</section>

</MainLayout>